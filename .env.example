# ─── Common to Both (API Server + Worker) ───────────────────────────────────

# Database connection (Format: postgresql://user:password@host:port/dbname)
DATABASE_URL="postgresql://myuser:mypassword@localhost:5432/karmayogi_db"

# Karmayogi platform API key and base URLs
KARMAYOGI_API_KEY="Bearer your-karmayogi-jwt-token"
KARMAYOGI_BASE_URL="https://igotkarmayogi.gov.in"

# Kafka — use 'kafka:9092' inside Docker, 'localhost:29092' when running locally
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_REQUEST_TOPIC=assessment.request
KAFKA_TOPIC=assessment.lifecycle.events

# Path where downloaded course content is stored (default: ./interactive_courses_data)
# INTERACTIVE_COURSES_PATH="./interactive_courses_data"

LOG_LEVEL="INFO"


# ─── API Server Only ─────────────────────────────────────────────────────────

SUNBIRD_SSO_URL="https://portal.dev.karmayogibharat.net/auth/"
SUNBIRD_SSO_REALM="sunbird"
REQUIRED_ROLE="AI_ASSESSMENT_CREATOR"

# Set to 'true' to bypass auth verification for local testing
DISABLE_AUTH_VERIFICATION=false

# Cleanup scheduler — removes old completed jobs
CLEANUP_RETENTION_DAYS=7
CLEANUP_SCHEDULE_HOUR=3
CLEANUP_SCHEDULE_MINUTE=0


# ─── Worker Only ─────────────────────────────────────────────────────────────

# Google Gemini / Vertex AI
GOOGLE_PROJECT_ID="your-google-project-id"
GOOGLE_LOCATION="us-central1"
GENAI_MODEL_NAME="gemini-2.5-pro"
# Path to your Vertex AI service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS="/app/credentials.json"

# Storage backend for uploaded files (standalone assessments)
# DOCUMENT_STORAGE_TYPE: "local" (default, single-node/Docker) | "gcs" (multi-pod/Kubernetes)
DOCUMENT_STORAGE_TYPE=local
GCS_CREDENTIALS="/app/gcs_credentials.json"  # path to GCS service account JSON (only needed when type=gcs)
GCS_BUCKET_NAME=""                            # e.g. "your-gcs-bucket-name" (only needed when type=gcs)
GCS_UPLOAD_PREFIX="ai-assessments/uploads"   # optional prefix inside the bucket

LEARNING_AI_BASE_URL="https://learning-ai.prod.karmayogibharat.net"

KAFKA_GROUP_ID=assessment_worker_group
MAX_CONCURRENCY=50
WORKER_BATCH_SIZE=50
MAX_ATTEMPTS=3
