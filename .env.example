# =============================================================================
# AI Assessment Service — Environment Variables
# =============================================================================
# Two services share this file: the API server and the Worker.
# Sections below indicate where each variable is required.
#   [BOTH]    — required by both API and Worker
#   [API]     — required only by the API server
#   [WORKER]  — required only by the Worker
# =============================================================================


# ─── [BOTH] Database ─────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://myuser:mypassword@localhost:5432/karmayogi_db"


# ─── [BOTH] Karmayogi Platform ───────────────────────────────────────────────
KARMAYOGI_API_KEY="Bearer your-karmayogi-jwt-token"
KARMAYOGI_BASE_URL="https://igotkarmayogi.gov.in"


# ─── [BOTH] Kafka ────────────────────────────────────────────────────────────
# Use 'kafka:9092' inside Docker, 'localhost:29092' when running locally
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_REQUEST_TOPIC=assessment.request           # API publishes, Worker consumes
KAFKA_TOPIC=assessment.lifecycle.events          # Worker publishes completion events


# ─── [BOTH] Storage ──────────────────────────────────────────────────────────
# Controls where files are stored and shared between the API and Worker pods.
#
# DOCUMENT_STORAGE_TYPE:
#   "local" — default, for single-node / Docker Compose setups
#   "gcs"   — required for Kubernetes / multi-pod deployments where API and
#             Worker run as separate pods and cannot share a local filesystem
#
# When set to "gcs", three categories of data are stored in GCS:
#   1. User-uploaded files (standalone assessments)   → GCS_UPLOAD_PREFIX
#   2. Course content fetched from Learning API        → GCS_COURSE_CONTENT_PREFIX
#      (persisted permanently so any pod can reuse it; no re-fetch on next job)
#   3. Generated output files (CSV, PDF, DOCX, JSON)  → written to /tmp per request
#      (served directly from the API pod; not stored in GCS)
DOCUMENT_STORAGE_TYPE=local

# The following GCS_* vars are only needed when DOCUMENT_STORAGE_TYPE=gcs
GCS_CREDENTIALS="/app/gcs_credentials.json"      # path to GCS service account JSON
GCS_BUCKET_NAME=""                                # e.g. "your-gcs-bucket-name"
GCS_UPLOAD_PREFIX="ai-assessments/uploads"        # prefix for user-uploaded files
GCS_COURSE_CONTENT_PREFIX="ai-assessments/course-content"  # prefix for fetched course VTT/PDF/metadata
GCS_OUTPUT_PREFIX="ai-assessments/outputs"        # reserved for future use


# ─── [BOTH] Misc ─────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"

# Path where downloaded course content is stored (default: ./interactive_courses_data)
# INTERACTIVE_COURSES_PATH="./interactive_courses_data"


# ─── [API] Authentication (Sunbird SSO / JWT) ────────────────────────────────
SUNBIRD_SSO_URL="https://portal.dev.karmayogibharat.net/auth/"
SUNBIRD_SSO_REALM="sunbird"
REQUIRED_ROLE="AI_ASSESSMENT_CREATOR"

# Set to 'true' to bypass auth verification for local testing
DISABLE_AUTH_VERIFICATION=false


# ─── [API] Cleanup Scheduler ─────────────────────────────────────────────────
# Removes old completed jobs from the DB
CLEANUP_RETENTION_DAYS=7
CLEANUP_SCHEDULE_HOUR=3
CLEANUP_SCHEDULE_MINUTE=0


# ─── [WORKER] Google Gemini / Vertex AI ──────────────────────────────────────
GOOGLE_PROJECT_ID="your-google-project-id"
GOOGLE_LOCATION="us-central1"
GENAI_MODEL_NAME="gemini-2.5-pro"

# Path to your Vertex AI service account JSON key file
# NOTE: This is a separate service account from GCS_CREDENTIALS above
GOOGLE_APPLICATION_CREDENTIALS="/app/credentials.json"


# ─── [WORKER] Karmayogi Learning-AI ──────────────────────────────────────────
LEARNING_AI_BASE_URL="https://learning-ai.prod.karmayogibharat.net"


# ─── [WORKER] Kafka Consumer Tuning ──────────────────────────────────────────
KAFKA_GROUP_ID=assessment_worker_group
MAX_CONCURRENCY=50
WORKER_BATCH_SIZE=50
MAX_ATTEMPTS=3
